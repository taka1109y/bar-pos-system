# ── Bar POS 環境変数テンプレート ─────────────────────────────
# このファイルを .env にコピーして値を設定してください:
#   cp .env.example .env
#
# 【重要】POSTGRES_PASSWORD は「最初の docker compose up の前」に設定すること。
#   PostgreSQL は空のデータボリュームへの初回起動時のみパスワードを適用します。
#   既に起動済みで変更したい場合はデータボリュームの作り直しが必要です。

POSTGRES_DB=bardb
POSTGRES_USER=bar
# 強力なパスワードに変更してください（英数記号16文字以上を推奨）
POSTGRES_PASSWORD=change_me_to_a_strong_password
